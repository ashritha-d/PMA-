{
  "name": "property-management-app",
  "version": "1.0.0",
  "description": "Full-stack Property Management Application",
  "scripts": {
    "install:all": "npm install --prefix server && npm install --prefix client-user && npm install --prefix client-admin",
    "start:server": "npm start --prefix server",
    "start:user": "npm start --prefix client-user",
    "start:admin": "npm start --prefix client-admin",
    "dev:server": "npm run dev --prefix server",
    "build:user": "npm run build --prefix client-user",
    "build:admin": "npm run build --prefix client-admin"
  },
  "keywords": ["property", "management", "real-estate", "react", "nodejs", "mongodb"]
}
